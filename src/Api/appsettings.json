{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=test_db;Username=dis;Password=dis"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "Jwt": {
    "Issuer": "CleanArchitectureApi",
    "Audience": "CleanArchitectureApiUsers",
    "SecretKey": "your-super-secret-key-change-this-in-production-minimum-256-bits!!",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4200"
    ]
  },
  "AllowedHosts": "*"
}
